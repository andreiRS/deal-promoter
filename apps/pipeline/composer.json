{
    "name": "deal-promoter/pipeline",
    "description": "Headless Deal Pipeline: runs one Cycle and renders a review page.",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/shared"
        },
        {
            "type": "path",
            "url": "../../packages/creatorsapi-php-sdk"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "amazon/creatorsapi-php-sdk": "^1.2",
        "deal-promoter/shared": "@dev",
        "doctrine/dbal": "^4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3",
        "symfony/console": "^8.0",
        "symfony/doctrine-bridge": "^8",
        "symfony/dotenv": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^13.0",
        "symfony/phpunit-bridge": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/",
            "DealPromoter\\Shared\\Tests\\": "../../packages/shared/tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "extra": {
        "runtime": {
            "disable_dotenv": true
        }
    },
    "scripts": {
        "qa": [
            "@php vendor/bin/phpunit",
            "@php vendor/bin/phpstan analyse",
            "@php vendor/bin/php-cs-fixer fix --dry-run --diff"
        ]
    }
}
