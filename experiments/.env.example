# Copy to .env (gitignored) and fill in. bun auto-loads .env.

# --- Keepa API (experiments 01-05) ---
KEEPA_API_KEY=your_keepa_api_key_here

# Default marketplace for experiments: 3 = amazon.de (Germany).
KEEPA_DOMAIN=3

# --- Amazon Creators API (experiments 06+) ---
# From Associates Central -> Tools -> Creators API. Secret is shown once.
CREATORS_CREDENTIAL_ID=your_credential_id_here
CREATORS_CREDENTIAL_SECRET=your_credential_secret_here
# Version encodes the auth path: 2.x = Cognito, 3.x = Login with Amazon.
CREATORS_VERSION=your_version_here
# Marketplace + partner tag are per-request (credentials are region-scoped).
CREATORS_MARKETPLACE=www.amazon.de
CREATORS_PARTNER_TAG=your_partner_tag_here
