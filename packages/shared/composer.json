{
    "name": "deal-promoter/shared",
    "description": "Cross-cutting integration code shared across Deal Promoter apps: Keepa client, Creators client, storage interface.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=8.4",
        "symfony/http-client": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "DealPromoter\\Shared\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DealPromoter\\Shared\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
