# Copy to .env and fill in. Only this .example file is committed; .env is git-ignored
# and you maintain it by hand. docker-compose reads .env via env_file.

# --- Symfony runtime ---
APP_ENV=dev
APP_DEBUG=1
# Generate one: php -r 'echo bin2hex(random_bytes(16));'
APP_SECRET=change_me_to_a_random_hex_string

# --- Postgres (the `postgres` compose service) ---
POSTGRES_DB=deal_promoter
POSTGRES_USER=deal_promoter
POSTGRES_PASSWORD=deal_promoter
# Used by the app to reach the postgres service over the compose network.
DATABASE_URL=postgresql://deal_promoter:deal_promoter@postgres:5432/deal_promoter?serverVersion=16&charset=utf8

# --- Keepa (discovery) ---
KEEPA_API_KEY=your_keepa_api_key_here
# Amazon marketplace domain id. 3 = amazon.de
KEEPA_DOMAIN=3

# --- Amazon Creators API (Live Snapshot + affiliate link) ---
# Credential Version 3.2 -> Login with Amazon (the SDK handles the auth fork).
# Value must be bare (no "v" prefix); the SDK accepts: 2.1 2.2 2.3 3.1 3.2 3.3.
CREATORS_CREDENTIAL_ID=your_credential_id_here
CREATORS_CREDENTIAL_SECRET=your_credential_secret_here
CREATORS_VERSION=3.2
CREATORS_MARKETPLACE=www.amazon.de
AMAZON_PARTNER_TAG=your_partner_tag_here

# --- WhatsApp gateway (WAHA + whatsapp-service, ADR 0001) ---
# Any non-empty random string; sent as the X-Api-Key header on every WAHA call.
# Generate one: php -r 'echo bin2hex(random_bytes(16));'
WAHA_API_KEY=change_me_to_a_random_string
# Local-only credentials for the WAHA dashboard and Swagger UI (username is "admin").
WAHA_DASHBOARD_PASSWORD=change_me_local_only
